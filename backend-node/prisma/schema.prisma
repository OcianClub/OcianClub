generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  senha    String
  criadoEm DateTime @default(now())
  role     Role     @default(USER)
}

model Categoria {
  id          Int           @id @default(autoincrement())
  nome        String        @unique
  faixaIdade  Int           @default(0)
  tipo        TipoCategoria
  jogadores   Jogador[]
  partidas    Partida[]
  times       Time[]        @relation("TimeCategorias")
  competicoes Competicao[]  @relation("CompeticaoCategorias")
}

model Time {
  id                 Int              @id @default(autoincrement())
  nome               String
  escudo             String?
  categoria_id       Int?
  competicoes        CompeticaoTime[]
  partidas_mandante  Partida[]        @relation("Mandante")
  partidas_visitante Partida[]        @relation("Visitante")
  categoria          Categoria?       @relation("TimeCategorias", fields: [categoria_id], references: [id])

  @@unique([nome, categoria_id])
  @@index([categoria_id])
}

model Competicao {
  id                  Int                 @id @default(autoincrement())
  nome                String
  ano                 Int
  tipo                TipoCompeticao
  jogadores_inscritos CompeticaoJogador[]
  times_inscritos     CompeticaoTime[]
  partidas            Partida[]
  categorias          Categoria[]         @relation("CompeticaoCategorias")
}

model Jogador {
  id           Int                 @id @default(autoincrement())
  nome         String
  cpf          String              @unique
  dtNasc       DateTime            @db.Date
  numCamisa    Int?
  posicao      String
  ativo        Boolean             @default(true)
  perfil_ml    String?
  scores_ml    Json?
  nota_geral   Float?
  categoria_id Int
  competicoes  CompeticaoJogador[]
  escalacoes   EscalacaoPartida[]
  eventos      Evento[]
  categoria    Categoria           @relation(fields: [categoria_id], references: [id])

  @@index([categoria_id])
}

model Partida {
  id                    Int                @id @default(autoincrement())
  mandante_id           Int
  visitante_id          Int
  gols_mandante         Int                @default(0)
  gols_visitante        Int                @default(0)
  horario               String?
  data                  DateTime           @db.Date
  local                 String?
  rodada                Int?
  grupo                 String?
  emCasa                Boolean            @default(true)
  status                StatusPartida      @default(AGENDADA)
  categoria_id          Int
  competicao_id         Int?
  jogadores_escalonados EscalacaoPartida[]
  eventos               Evento[]
  categoria             Categoria          @relation(fields: [categoria_id], references: [id])
  competicao            Competicao?        @relation(fields: [competicao_id], references: [id])
  mandante              Time               @relation("Mandante", fields: [mandante_id], references: [id])
  visitante             Time               @relation("Visitante", fields: [visitante_id], references: [id])

  @@unique([competicao_id, categoria_id, rodada])
  @@index([data])
  @@index([categoria_id])
  @@index([competicao_id])
}

model Evento {
  id         Int        @id @default(autoincrement())
  partida_id Int
  tipo       TipoEvento
  periodo    Int
  minuto     Int?
  doOcian    Boolean    @default(true)
  jogador_id Int?
  jogador    Jogador?   @relation(fields: [jogador_id], references: [id])
  partida    Partida    @relation(fields: [partida_id], references: [id], onDelete: Cascade)

  @@index([partida_id])
}

model CompeticaoTime {
  id            Int        @id @default(autoincrement())
  competicao_id Int
  time_id       Int
  competicao    Competicao @relation(fields: [competicao_id], references: [id], onDelete: Cascade)
  time          Time       @relation(fields: [time_id], references: [id], onDelete: Cascade)

  @@unique([competicao_id, time_id])
}

model CompeticaoJogador {
  id            Int        @id @default(autoincrement())
  competicao_id Int
  jogador_id    Int
  inscritoEm    DateTime   @default(now())
  competicao    Competicao @relation(fields: [competicao_id], references: [id], onDelete: Cascade)
  jogador       Jogador    @relation(fields: [jogador_id], references: [id], onDelete: Cascade)

  @@unique([competicao_id, jogador_id])
  @@index([competicao_id])
}

model EscalacaoPartida {
  id         Int     @id @default(autoincrement())
  partida_id Int
  jogador_id Int
  numCamisa  Int
  titular    Boolean @default(false)
  jogador    Jogador @relation(fields: [jogador_id], references: [id], onDelete: Cascade)
  partida    Partida @relation(fields: [partida_id], references: [id], onDelete: Cascade)

  @@unique([partida_id, jogador_id])
  @@unique([partida_id, numCamisa])
}

model CampeonatoClassificacao {
  id                Int      @id @default(autoincrement())
  temporada         String
  titulo            String
  divisao           String
  categoria         String
  eventoId          Int
  tipoTabela        String
  grupo             String
  posicao           Int
  clube             String
  pontos            Int
  jogos             Int
  vitorias          Int
  empates           Int
  derrotas          Int
  golsPro           Int
  golsContra        Int
  saldo             Int
  average           Float
  mediaGolsMarcados Float
  mediaGolsSofridos Float
  indiceTecnico     Float
  destaque          Boolean  @default(false)
  atualizadoEm      DateTime @default(now())

  @@index([temporada, titulo, divisao, categoria, tipoTabela])
}

enum Role {
  ADMIN
  USER
}

enum TipoCategoria {
  INICIACAO
  BASE
}

enum TipoCompeticao {
  INICIACAO
  BASE
}

enum StatusPartida {
  AGENDADA
  PREPARADA
  AO_VIVO
  FINALIZADA
  CANCELADA
}

enum TipoEvento {
  GOL
  ASSISTENCIA
  DEFESA
  CARTAO_AMARELO
  CARTAO_VERMELHO
  CARTAO_AZUL
  FALTA
}
