// Este arquivo define a estrutura do banco de dados PostgreSQL.
// Após configurar o .env, rode: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── USUÁRIOS ──────────────────────────────────────────────
model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String  
  criadoEm  DateTime @default(now())
  role      Role     @default(USER)
}

enum Role {
  ADMIN
  USER
}

// ── CATEGORIAS (Os Subs) ──────────────────────────────────
model Categoria {
  id        Int           @id @default(autoincrement())
  nome      String 
  tipo      TipoCategoria
  
  jogadores Jogador[]
  partidas  Partida[]
  times     Time[]        @relation("TimeCategorias") // Relação N:N perfeita!
}

enum TipoCategoria {
  INICIACAO
  BASE
}

// ── COMPETIÇÕES ───────────────────────────────────────────
model Competicao {
  id                    Int       @id @default(autoincrement())
  nome                  String
  ano                   Int 
  
  times_inscritos       CompeticaoTime[]    // <-- NOVO: Para gerar tabela de classificação
  jogadores_inscritos   CompeticaoJogador[]
  partidas              Partida[]
}

// ── TIMES (Instituições) ──────────────────────────────────
model Time {
  id                 Int         @id @default(autoincrement())
  nome               String
  escudo             String?
  
  categorias         Categoria[] @relation("TimeCategorias")
  competicoes        CompeticaoTime[] // <-- NOVO: Saber de quais campeonatos participou

  partidas_mandante  Partida[] @relation("Mandante")
  partidas_visitante Partida[] @relation("Visitante")
  eventos            Evento[]
}

// ── JOGADORES (Elenco do Ocian) ───────────────────────────
model Jogador {
  id            Int       @id @default(autoincrement())
  nome          String
  cpf           String    @unique
  dtNasc        DateTime  @db.Date
  numCamisa     Int?      
  posicao       String

  perfil_ml     String?
  scores_ml     Json?
  nota_geral    Float?    
  
  categoria_id  Int 
  categoria     Categoria @relation(fields: [categoria_id], references: [id])
  
  competicoes   CompeticaoJogador[]
  escalacoes    EscalacaoPartida[]
  eventos       Evento[]

  @@index([categoria_id]) // <-- PERFORMANCE: Busca rápida de elenco por sub
}

// ── PARTIDAS (Os Eventos) ─────────────────────────────────
model Partida {
  id                    Int       @id @default(autoincrement())
  
  mandante_id           Int
  mandante              Time      @relation("Mandante", fields: [mandante_id], references: [id])

  visitante_id          Int
  visitante             Time      @relation("Visitante", fields: [visitante_id], references: [id])
  
  gols_mandante         Int       @default(0)
  gols_visitante        Int       @default(0)

  data                  DateTime  @default(now())
  horario               String?   // "19:30"
  local                 String?     
  emCasa                Boolean   @default(true)
  status                StatusPartida @default(AGENDADA)
  
  categoria_id          Int?
  categoria             Categoria? @relation(fields: [categoria_id], references: [id])

  competicao_id         Int?      
  competicao            Competicao? @relation(fields: [competicao_id], references: [id])
  
  jogadores_escalonados EscalacaoPartida[]
  eventos               Evento[]

  @@index([data])           // <-- PERFORMANCE: Para carregar o calendário rápido
  @@index([categoria_id])   // <-- PERFORMANCE: Para filtrar jogos do Sub rápido
  @@index([competicao_id])
}

enum StatusPartida {
  AGENDADA
  AO_VIVO
  FINALIZADA
}

// ── EVENTOS (O Scout / IA) ────────────────────────────────
model Evento {
  id          Int        @id @default(autoincrement())
  
  // <-- CASCADE: Se apagar a partida, apaga os eventos dela pra não dar erro fantasma
  partida_id  Int
  partida     Partida    @relation(fields: [partida_id], references: [id], onDelete: Cascade) 
  
  tipo        TipoEvento
  minuto      Int

  time_id     Int
  time        Time       @relation(fields: [time_id], references: [id])
  
  jogador_id  Int?
  jogador     Jogador?   @relation(fields: [jogador_id], references: [id])

  @@index([partida_id])
}

// ATUALIZADO AQUI: Removido DESARME e adicionado DEFESA
enum TipoEvento {
  GOL
  ASSISTENCIA
  DEFESA
  CARTAO_AMARELO
  CARTAO_VERMELHO
  FALTA
}

// ── TABELAS DE LIGAÇÃO (JOIN TABLES) ──────────────────────

// NOVO: Inscreve o Time no Campeonato (Para gerar a Classificação)
model CompeticaoTime {
  id            Int         @id @default(autoincrement())
  competicao_id Int
  competicao    Competicao  @relation(fields: [competicao_id], references: [id], onDelete: Cascade)
  time_id       Int
  time          Time        @relation(fields: [time_id], references: [id], onDelete: Cascade)

  @@unique([competicao_id, time_id])
}

model CompeticaoJogador {
  id            Int         @id @default(autoincrement())
  competicao_id Int       
  competicao    Competicao  @relation(fields: [competicao_id], references: [id], onDelete: Cascade)
  jogador_id    Int
  jogador       Jogador     @relation(fields: [jogador_id], references: [id], onDelete: Cascade)

  @@unique([competicao_id, jogador_id])
}

model EscalacaoPartida {
  id          Int       @id @default(autoincrement())
  
  // <-- CASCADE: Se apagar o jogo, apaga a escalação daquele jogo
  partida_id  Int         
  partida     Partida   @relation(fields: [partida_id], references: [id], onDelete: Cascade)
  
  jogador_id  Int
  jogador     Jogador   @relation(fields: [jogador_id], references: [id], onDelete: Cascade)

  numCamisa   Int
  titular     Boolean   @default(false)  
  
  @@unique([partida_id, jogador_id])
}